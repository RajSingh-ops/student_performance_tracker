# Render Environment Variables Template
# Copy these variable names and values into Render Service Settings > Environment Variables

# Django Settings
SECRET_KEY=django-insecure-YOUR-VERY-LONG-SECRET-KEY-HERE-CHANGE-THIS-IN-PRODUCTION
DEBUG=0
ALLOWED_HOSTS=.onrender.com
DJANGO_SETTINGS_MODULE=yearscore.settings_prod

# Database
# If using Render's managed PostgreSQL: Render will set DATABASE_URL automatically
# If using external DB:
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Email (optional, for password reset emails)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Optional: S3/Media Storage (if you set up S3 for uploads)
# USE_S3=True
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_STORAGE_BUCKET_NAME=your-bucket-name

# Logging
LOG_LEVEL=INFO

# Security (for production)
SECURE_SSL_REDIRECT=True
